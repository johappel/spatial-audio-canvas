# URL des WebSocket-Signalling-Dienstes (siehe docs/install-ws-service.md).
# Lokal:   ws://localhost:8787
# Prod:    wss://dein-signaling-host.example/ws
VITE_SIGNALING_URL=ws://localhost:8787

# Optionale STUN/TURN-Konfiguration (kommagetrennte URLs).
VITE_STUN_URLS=stun:stun.l.google.com:19302
# VITE_TURN_URL=turns:dein-turn-host.example:5349
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=